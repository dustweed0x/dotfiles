# Configuraciones que aplican a todos los host
# Aqui se agregan todas las lineas que se repiten entre todos los host
Host *
    	# Indica el intervalo de tiempo(seg) que usara el agente local para mandar keepalive messages 
    	# y así evitar que se cuelgue nuestra conexión de `ssh` 
    	# luego de algunos minutos de inactividad (error`broken pipeline`).
	ServerAliveInterval 240
	# Activa el agente ssh para que al movernos a otro servidor cargue nuestra key
	# Requisitos:
	# server1: origen | server2: destino1 | server3: destino2
	# server1: Debe generar su par de claves con ssh-keygen
	# server2 | server3 deben autotizar la clave de server1
	# Ahora server1 puede conectarse a server2 y desde server2 a server3
	ForwardAgent yes
	# Permite que los host conocidos se muestren si hashe en el archivo know_hosts
	# HashKnownHosts no
Host sunat*
  	Port 22
	User root
	
