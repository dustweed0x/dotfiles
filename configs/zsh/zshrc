# Transient Prompt para Starship
function zle-line-init() {
  emulate -L zsh
  [[ $CONTEXT == start ]] || return 0
  while true; do
    zle .recursive-edit
    local -i ret=$?
    [[ $ret == 0 && $KEYS == $'\4' ]] || break
    [[ -o ignore_eof ]] || exit 0
  done

  # 1. Guardamos el prompt original de 2 líneas de Starship intacto
  local saved_prompt="$PROMPT"
  local saved_rprompt="$RPROMPT"

  # 2. Definimos la versión minimalista solo para el historial
  PROMPT="%F{#C574DD} %~ 👾 %f"
  RPROMPT=""

  # 3. Redibujamos la pantalla congelando el prompt minimalista arriba
  zle .reset-prompt

  # 4. Restauramos internamente el prompt completo para la siguiente línea
  PROMPT="$saved_prompt"
  RPROMPT="$saved_rprompt"

  if (( ret )); then zle .send-break; else zle .accept-line; fi
  return ret
}
zle -N zle-line-init


