# --- Variables Globales de Diseño Crypto ---
# Centralizamos los códigos ANSI complejos para que el código sea fácil de leer
C_BTC="\e[38;2;242;162;114m"
C_ETH="\e[38;2;183;189;248m"
C_GRAY="\e[38;2;190;190;193m"
C_RST="\e[0m"

function coin() {
  local url="https://fapi.binance.com/fapi/v1/ticker/price?symbols=%5B%22BTCUSDT%22,%22ETHUSDT%22%5D"
  local data=$(curl -s "$url")
  local btc_raw=$(echo "$data" | jq -r '.[] | select(.symbol=="BTCUSDT") | .price')
  local eth_raw=$(echo "$data" | jq -r '.[] | select(.symbol=="ETHUSDT") | .price')

  if [[ -z "$btc_raw" || "$btc_raw" == "null" ]]; then
    echo -e "\n \e[31m Error de conexión con Binance$C_RST\n"
  else
    echo -e ""
    printf "  ${C_BTC}%-5s${C_RST} \e[1m%9.2f${C_RST} \e[2mUSD${C_RST}\n" " BTC" "$btc_raw"
    printf "  ${C_ETH}%-5s${C_RST} \e[1m%9.2f${C_RST} \e[2mUSD${C_RST}\n" " ETH" "$eth_raw"
    echo -e ""
  fi
}

function coinlive() {
  # Definimos variables como flotantes para comparaciones exactas
  typeset -F old_btc=0.0 old_eth=0.0
  # Ocultar el cursor y limpiar pantalla al salir (Ctrl+C)
  echo -ne "\e[?25l"
  trap 'echo -ne "\e[?25h"; clear; return' INT

  while true; do
    # 1. Obtención de datos (Llamada única para sincronía total)
    local url="https://fapi.binance.com/fapi/v1/ticker/price?symbols=%5B%22BTCUSDT%22,%22ETHUSDT%22%5D"
    local data=$(curl -s "$url")
    local btc=$(echo "$data" | jq -r '.[] | select(.symbol=="BTCUSDT") | .price' 2>/dev/null)
    local eth=$(echo "$data" | jq -r '.[] | select(.symbol=="ETHUSDT") | .price' 2>/dev/null)
    local hora=$(date +%H:%M:%S)

    # Validar datos antes de procesar
    [[ "$btc" == "null" || -z "$btc" ]] && continue

    # 2. Lógica de Tendencia BTC (Círculo gris '○' si no hay cambio)
    local btc_t="${C_GRAY}● " btc_c="${C_GRAY}"
    if (( old_btc > 0 )); then
      (( btc > old_btc )) && { btc_t="\e[32m▲ "; btc_c="\e[32m"; }
      (( btc < old_btc )) && { btc_t="\e[31m▼ "; btc_c="\e[31m"; }
    fi

    # 3. Lógica de Tendencia ETH
    local eth_t="${C_GRAY}● " eth_c="${C_GRAY}"
    if (( old_eth > 0 )); then
      (( eth > old_eth )) && { eth_t="\e[32m▲ "; eth_c="\e[32m"; }
      (( eth < old_eth )) && { eth_t="\e[31m▼ "; eth_c="\e[31m"; }
    fi

    # 4. Construcción de la Interfaz (Fuerza el diseño vertical)
    # \e[H\e[J posiciona el cursor al inicio para evitar parpadeos
    local out="\e[H\e[J"
    out+="\e[38;2;197;116;221m \e[38;2;40;42;54;48;2;197;116;221m CRYPTO MONITOR \e[0;38;2;197;116;221m$C_RST \e[2m$hora$C_RST\n\n"
    out+="$(printf "  ${C_BTC}%-5s$C_RST %b \e[1m%s%9.2f$C_RST \e[2mUSD$C_RST" " BTC" "$btc_t" "$btc_c" "$btc")"$'\n'
    out+="$(printf "  ${C_ETH}%-5s$C_RST %b \e[1m%s%9.2f$C_RST \e[2mUSD$C_RST" " ETH" "$eth_t" "$eth_c" "$eth")"$'\n'
    # 5. Impresión Síncrona (Muestra todo el bloque a la vez)
    echo -ne "$out"

    # Guardar valores para la comparativa del siguiente segundo
    old_btc=$btc; old_eth=$eth
    sleep 1
  done
}

# 1. El "Actualizador" (Corre en silencio en el fondo cada 1s)
function crypto_fetcher() {
  while true; do
    # 1. Datos Crypto
    local data=$(curl -s "https://fapi.binance.com/fapi/v1/ticker/price?symbols=%5B%22BTCUSDT%22,%22ETHUSDT%22%5D")
    echo "$data" > /dev/shm/crypto_prices.json
    
    # 2. Datos de Sistema (CPU y RAM super rápidos)
    # CPU: Suma procesos de usuario y sistema
    local cpu=$(top -bn1 | awk '/Cpu\(s\)/ {printf("%02d%%", $2 + $4)}')
    # RAM: Porcentaje de uso
    local ram=$(free -m | awk '/Mem:/ {printf("%02d%%", $3/$2 * 100)}')
    echo "$cpu|$ram" > /dev/shm/sys_stats.txt
    
    sleep 1
  done
}

# 2. El "Dibujador" (Rápido, lee de la RAM, no parpadea)
function crypto_bar_fast() {
  typeset -F old_btc=0.0 old_eth=0.0
  # Inicializamos las variables de tendencia fuera del bucle para que persistan
  local btc_t="${C_GRAY}● " btc_c="${C_GRAY}"
  local eth_t="${C_GRAY}● " eth_c="${C_GRAY}"

  # Capturamos el ID de esta pestaña de terminal
  local my_tty=$(tty)

  while true; do
    # Revisa qué programa está activo en primer plano (+). Si es vim, se pausa.
    local fg_process=$(ps -t "$my_tty" -o stat,comm 2>/dev/null | awk '/\+/ {print $2}')
    if [[ "$fg_process" =~ (vi|vim|nvim|nano|less|yazi|batcat) ]]; then
      sleep 1
      continue
    fi
    	  
    # Validamos que ambos archivos de datos existan
    [[ ! -f /dev/shm/crypto_prices.json || ! -f /dev/shm/sys_stats.txt ]] && sleep 1 && continue
    
    local data=$(cat /dev/shm/crypto_prices.json)
    local sys=$(cat /dev/shm/sys_stats.txt) 
    
    local btc=$(echo "$data" | jq -r '.[] | select(.symbol=="BTCUSDT") | .price' 2>/dev/null)
    local eth=$(echo "$data" | jq -r '.[] | select(.symbol=="ETHUSDT") | .price' 2>/dev/null)
    
    local cpu_val="${sys%%|*}"
    local ram_val="${sys##*|}"

    local hora=$(date +%H:%M:%S)

    # --- Lógica de Tendencia BTC (Solo se actualiza si el precio cambia) ---
    if (( btc != old_btc && old_btc > 0 )); then
      (( btc > old_btc )) && { btc_t="\e[32m▲ "; btc_c="\e[32m"; }
      (( btc < old_btc )) && { btc_t="\e[31m▼ "; btc_c="\e[31m"; }
      old_btc=$btc
    elif (( old_btc == 0 )); then old_btc=$btc; fi

    # --- Lógica de Tendencia ETH (Solo se actualiza si el precio cambia) ---
    if (( eth != old_eth && old_eth > 0 )); then
      (( eth > old_eth )) && { eth_t="\e[32m▲ "; eth_c="\e[32m"; }
      (( eth < old_eth )) && { eth_t="\e[31m▼ "; eth_c="\e[31m"; }
      old_eth=$eth
    elif (( old_eth == 0 )); then old_eth=$eth; fi

    # --- Renderizado de la Barra ---
    local bar="\e[s\e[999;1H\e[48;2;29;31;40m\e[K "
    bar+="$(printf "${C_BTC} BTC$C_RST %b %b%9.2f$C_RST  " "$btc_t" "$btc_c" "$btc")"
    bar+="$(printf "${C_ETH} ETH$C_RST %b %b%9.2f$C_RST  " "$eth_t" "$eth_c" "$eth")"
    
    bar+="\e[38;2;136;151;244m CPU: $cpu_val$C_RST  "
    bar+="\e[38;2;85;111;255m RAM: $ram_val$C_RST  "
    
    bar+="\e[2m| $hora$C_RST\e[u"
    
    echo -ne "$bar"
    sleep 0.2
  done
}

function cryptobar() {
  pkill -f crypto_fetcher 2>/dev/null
  pkill -f crypto_bar_fast 2>/dev/null
  crypto_fetcher &!
  crypto_bar_fast &!
  echo -e "\e[32m✔\e[0m Crypto Bar iniciada (Fondo)."
}
alias cryptobar-stop="pkill -f crypto_fetcher; pkill -f crypto_bar_fast; echo -e '\e[31m✘\e[0m Barra detenida.'"

# ============================================================================
# SCRIPT DE BARRA EXCLUSIVO PARA ZELLIJ
